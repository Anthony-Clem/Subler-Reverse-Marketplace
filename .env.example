# Database Configuration
# Local Docker development URL or Neon Postgres production connection pooler URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/subler_reverse"

# Auth.js Configuration
# Generate a secret locally by running `npx auth secret` or using openssl
AUTH_SECRET="your-generated-auth-secret"
# API Key for sending magic link emails via Resend
AUTH_RESEND_KEY="re_..."
# Default sender address for Auth.js Resend provider
RESEND_FROM="onboarding@resend.dev"
# Auth Base URL (defaults to NEXT_PUBLIC_APP_URL if omitted in local dev, but good to define)
AUTH_URL="http://localhost:3000"

# Arcjet Configuration (for rate-limiting and security shielding)
# Obtain from your Arcjet dashboard
ARCJET_KEY="ajkey_..."

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"

